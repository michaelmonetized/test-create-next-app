# OpenRouter (layout accessibility assistant chat)
# https://openrouter.ai/
OPENROUTER_API_KEY=
# Optional — comma-separated ids tried in order; then built-in fallbacks (openrouter/free, xiaomi/mimo-v2-flash:free, …).
# The old id openrouter/openrouter/free is invalid; OpenRouter exposes "Free Models Router" as:
# OPENROUTER_MODEL=openrouter/free
# List free-tier ids (requires jq): curl -s https://openrouter.ai/api/v1/models | jq -r '.data[] | select(.id|test(":free$")) | .id'
# Optional — OpenRouter rankings / attribution:
# OPENROUTER_HTTP_REFERER=https://your-site.example
