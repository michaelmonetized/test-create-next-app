{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.ts",
    "src/index.tsx",
    "src/index.js",
    "src/index.jsx",
    "src/main.ts",
    "src/main.tsx",
    "src/main.js",
    "src/main.jsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.test.js",
    "**/*.test.jsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.spec.js",
    "**/*.spec.jsx"
  ],
  "ignoreDependencies": ["@tailwindcss/forms", "@tailwindcss/typography", "shadcn"],
  "duplicates": {
    "threshold": 3.0,
    "ignoreImports": true,
    "ignore": ["app/privacy/page.tsx", "app/terms/page.tsx"]
  },
  "health": {
    "maxCrap": 100.0,
    "ignore": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"]
  },
  "audit": {
    "dupesBaseline": ".fallow/dupes-baseline.json"
  },
  "overrides": [
    {
      "files": ["**/*.test.ts", "**/*.test.tsx", "**/*.spec.ts", "**/*.spec.tsx"],
      "rules": {
        "unused-files": "off"
      }
    }
  ],
  "rules": {}
}
