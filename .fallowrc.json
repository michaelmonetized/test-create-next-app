{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "app/**/{page,layout,route,global-error,error,not-found,template,default}.{ts,tsx,js,jsx}",
    "app/{manifest,robots,sitemap,apple-icon,icon-192.png/route,icon-512.png/route}.{ts,tsx,js,jsx}",
    "instrumentation.{ts,tsx,js,jsx}",
    "instrumentation-client.{ts,tsx,js,jsx}",
    "proxy.{ts,tsx,js,jsx}",
    "__tests__/**/*.{ts,tsx,js,jsx}",
    "scripts/**/*.{ts,tsx,js,jsx,mjs}"
  ],
  "ignorePatterns": [
    ".next/**",
    "node_modules/**",
    "convex/_generated/**",
    "public/**",
    "app/max.css"
  ],
  "rules": {
    "unused-dependencies": "warn"
  },
  "audit": {
    "deadCodeBaseline": ".fallow/baselines/dead-code.json",
    "healthBaseline": ".fallow/baselines/health.json",
    "dupesBaseline": ".fallow/baselines/dupes.json"
  }
}
